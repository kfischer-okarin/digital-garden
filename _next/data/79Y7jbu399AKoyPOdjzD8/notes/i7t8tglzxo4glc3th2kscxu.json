{"pageProps":{"note":{"id":"i7t8tglzxo4glc3th2kscxu","title":"RujiK the Comatose","desc":"","updated":1652664428016,"created":1652663770875,"custom":{},"fname":"reference.inspiration.gamedev.rujik-the-comatose","type":"note","vault":{"fsPath":".","name":"digital-garden","selfContained":true},"contentHash":"49aafbd1224afdeb8949012ff307ba57","links":[],"anchors":{"rujik-the-comatose":{"type":"header","text":"RujiK the Comatose","value":"rujik-the-comatose","line":8,"column":0,"depth":1}},"children":[],"parent":"kt07otipr8ma6csjgkqwoh7","data":{}},"body":"<h1 id=\"rujik-the-comatose\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#rujik-the-comatose\"></a>RujiK the Comatose</h1>\n<p><img src=\"/digital-garden/assets/images/rujik-monster-crossbreeding.png\" alt=\"Crossbreeding Screenshot\" style=\"height:323px;\"></p>\n<ul>\n<li>\n<p>Procedural Monsters</p>\n</li>\n<li>\n<p>Procedural animations</p>\n</li>\n<li>\n<p>Crossbreeding</p>\n</li>\n<li>\n<p><img src=\"/digital-garden/assets/twitter-icon.svg\" alt=\"Twitter Icon\" style=\"height:1rem;\"> <a href=\"https://twitter.com/TheRujiK\">@TheRujiK</a></p>\n</li>\n<li>\n<p><img src=\"/digital-garden/assets/youtube-icon.svg\" alt=\"Youtube Icon\" style=\"height:1rem;\"> <a href=\"https://www.youtube.com/channel/UCah7IyEzRnRdttwDGDdy_gw\">Youtube Channel</a></p>\n</li>\n</ul>\n<iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/a87tB__3KEs\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen></iframe>","noteIndex":{"id":"w4mxpqpj9ftyo6pw17k3wj6","title":"Home","desc":"","updated":1655543408062,"created":1648806032875,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":".","name":"digital-garden","selfContained":true},"contentHash":"85274ee61d0bc9adc52197cbfa78a37d","links":[{"type":"wiki","from":{"fname":"root","id":"w4mxpqpj9ftyo6pw17k3